{
	"compilerOptions": {
		"outDir": "./dist-server",
		"rootDir": ".",
		"module": "ESNext",
		"moduleResolution": "node",
		"target": "ES2022",
		"lib": ["ES2022"],
		"types": ["node"],
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"strict": true,
		"skipLibCheck": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"noImplicitReturns": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "react-jsx"
	},
	"include": [
		"server",
		"worker/do/AgentService.ts",
		"worker/do/closeAndParseJson.ts",
		"worker/prompt",
		"shared/models.ts",
		"shared/format",
		"shared/schema",
		"shared/types"
	],
	"exclude": ["node_modules", "client"]
}
